function saveGSUrl() {
    const url = document.getElementById('gs-url-input');
    if (!url) return;
    const val = url.value.trim();
    if (val && !val.startsWith('https://script.google.com')) {
        toast('URL غير صحيح. يجب أن يبدأ بـ https://script.google.com', 'error');
        return;
    }
