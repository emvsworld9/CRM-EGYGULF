            .llogo-sub  { font-size:11px; color:var(--text3); margin-top:2px; }
            .ltabs {
                display:flex; background:var(--surface2); border-radius:10px;
                padding:4px; margin-bottom:22px; gap:0;
            }
            .ltab {
                flex:1; padding:8px; text-align:center; font-size:12.5px;
