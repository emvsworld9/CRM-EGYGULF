                    });
                }
                const titleEl = document.getElementById('page-title');
                if (titleEl) titleEl.textContent = pageNames[page] || page;
                renderPage(page);
            }

            function renderPage(p) {
                if (p === 'dashboard') renderDashboard();
                if (p === 'leads') {
                    populateFilterSelects();
                    renderLeadTable();
                }
                if (p === 'sales') renderSalesCards();
                if (p === 'social') renderSocialCards();
                if (p === 'teamlink') renderTeamPairs();
                if (p === 'leaderboard') renderLeaderboard();
                if (p === 'reports') renderReports();
                if (p === 'notifications') renderNotifications();
                if (p === 'admin') renderAdmin();
                if (p === 'duplicates') renderDuplicates();
                if (p === 'addlead') populateLeadFormSelects();
            }

            // ═══════════════════════════════════════
            // UTILITIES
            // ═══════════════════════════════════════
            function genId(prefix) {
                return prefix + '-' + Date.now().toString(36).toUpperCase();
            }

            function fmt(n) {
                return n ? '$' + Number(n).toLocaleString() : '-'
            }

            function pct(a, b) {
                return b ? Math.round(a / b * 100) + '%' : '0%'
            }

            function ago(iso) {
                const d = new Date(iso),
                    now = new Date();
                const diff = Math.floor((now - d) / 1000);
                if (diff < 60) return 'Just now';
                if (diff < 3600) return Math.floor(diff / 60) + ' min ago';
                if (diff < 86400) return Math.floor(diff / 3600) + ' hr ago';
                return d.toLocaleDateString();
            }

            const STATUS_TAG = {
                'New': 'tag-new',
                'Contacted': 'tag-contacted',
                'Interested': 'tag-interested',
                'Follow-up': 'tag-followup',
                'Negotiation': 'tag-negotiation',
                'Closed Won': 'tag-won',
                'Closed Lost': 'tag-lost',
                'No Response': 'tag-noresponse'
            };
            const PRI_TAG = {
                'High': 'tag-high',
                'Medium': 'tag-medium',
                'Low': 'tag-low'
            };

            function empName(id) {
                const e = LS.get('employees').find(x => x.id === id);
                return e ? e.name : '-';
            }

            function empInitials(name) {
                return name.split(' ').map(w => w[0]).slice(0, 2).join('').toUpperCase();
            }

            // ═══════════════════════════════════════
            // TOAST
            // ═══════════════════════════════════════
            function toast(msg, type = '') {
                const c = document.getElementById('toast-container');
                const t = document.createElement('div');
                t.className = 'toast ' + (type || '');
                t.textContent = msg;
                c.appendChild(t);
                setTimeout(() => {
                    t.style.opacity = '0';
                    t.style.transform = 'translateX(40px)';
                    t.style.transition = '.3s';
                    setTimeout(() => t.remove(), 300);
                }, 2500);
            }

            // ═══════════════════════════════════════
            // MODAL
            // ═══════════════════════════════════════
            function closeModal(id) {
                document.getElementById(id).classList.remove('open');
            }

            function openModal(id) {
                document.getElementById(id).classList.add('open');
            }

            document.querySelectorAll('.modal-overlay').forEach(function(o) {
                o.addEventListener('click', function(e) {
                    if (e.target === this) this.classList.remove('open');
                });
            });

            // ═══════════════════════════════════════
            // CONFIRM DIALOG
            // ═══════════════════════════════════════
            let confirmCb = null;

            function confirm(title, text, cb, icon = '🗑️') {
                document.getElementById('confirm-title').textContent = title;
                document.getElementById('confirm-text').textContent = text;
                document.getElementById('confirm-icon').textContent = icon;
                confirmCb = cb;
                document.getElementById('confirm-overlay').classList.add('open');
            }

            function closeConfirm() {
                document.getElementById('confirm-overlay').classList.remove('open');
                if (confirmCb) {
                    confirmCb();
                    confirmCb = null;
                }
            }
            document.getElementById('confirm-overlay').addEventListener('click', function(e) {
                if (e.target === this) {
                    confirmCb = null;
                    this.classList.remove('open');
                }
            });

            // ═══════════════════════════════════════
            // DUPLICATE DETECTION
            // ═══════════════════════════════════════
            let dupTimer = null;

            function liveCheckDup(inputId, alertId, nameId) {
                clearTimeout(dupTimer);
                dupTimer = setTimeout(() => {
                    const val = document.getElementById(inputId).value.replace(/\s+/g, '');
                    if (val.length < 7) {
                        document.getElementById(alertId).style.display = 'none';
                        return;
                    }
                    const leads = getMyLeads(LS.get('leads'));
                    const match = leads.find(l => {
                        const p1 = (l.phone || '').replace(/\s+/g, '');
                        const p2 = (l.phone2 || '').replace(/\s+/g, '');
                        const wa = (l.whatsapp || '').replace(/\s+/g, '');
                        return p1 === val || p2 === val || wa === val ||
                            normalizePhone(p1) === normalizePhone(val) ||
                            normalizePhone(wa) === normalizePhone(val);
                    });
                    if (match) {
                        document.getElementById(alertId).style.display = 'flex';
                        document.getElementById(nameId).textContent = match.name + ' (' + match.company + ')';
                    } else {
                        document.getElementById(alertId).style.display = 'none';
                    }
                }, 500);
            }

            function normalizePhone(p) {
                if (!p) return '';
                p = p.replace(/[\s\-\(\)\.]/g, '');
                if (p.startsWith('00')) p = '+' + p.slice(2);
                if (!p.startsWith('+')) {
                    if (p.startsWith('0')) p = p.slice(1);
                }
                return p;
            }

            // ═══════════════════════════════════════
            // SAVE LEAD
            // ═══════════════════════════════════════
            function getField(id) {
                const e = document.getElementById(id);
                return e ? e.value.trim() : '';
            }

            function saveLead() {
                const name = getField('nl-name'),
                    phone = getField('nl-phone');
                if (!name) {
                    toast('Name is required', 'error');
                    return;
                }
                if (!phone) {
                    toast('Phone is required', 'error');
                    return;
                }
                const leads = LS.get('leads');
                const normNew = normalizePhone(phone.replace(/\s+/g, ''));
                const dup = leads.find(l => normalizePhone((l.phone || '').replace(/\s+/g, '')) === normNew);
                if (dup) {
                    if (!window.confirm('Duplicate detected: ' + dup.name + '. Save anyway?')) return;
                    logDup(name, dup.name, 'Phone match', 'Manual override');
                }
                const lead = {
                    id: genId('EG'),
                    name,
                    company: getField('nl-company'),
                    phone,
                    phone2: getField('nl-phone2'),
                    whatsapp: getField('nl-whatsapp'),
                    email: getField('nl-email'),
                    country: getField('nl-country'),
                    city: getField('nl-city'),
                    btype: getField('nl-btype'),
                    product: getField('nl-product'),
                    source: getField('nl-source'),
                    socialEmp: getField('nl-social-emp'),
                    salesEmp: getField('nl-sales-emp'),
                    status: getField('nl-status') || 'New',
                    response: getField('nl-response') || 'No Response',
                    priority: getField('nl-priority'),
                    deal: parseFloat(getField('nl-deal')) || 0,
                    notes: getField('nl-notes'),
                    samples: getField('nl-samples') || 'no',
                    sampleResult: getField('nl-sample-result') || '',
                    followup: getField('nl-followup'),
                    added: new Date().toISOString()
                };
                leads.push(lead);
                LS.set('leads', leads);
                GS.pushLead(lead);
                addNotification('success', 'New Lead Added: ' + name, 'Deal: ' + fmt(lead.deal) + ' · ' + lead.country);
                toast('Lead saved: ' + name, 'success');
                clearLeadForm();
                nav('leads', null);
            }

            function saveQuickLead() {
                const name = getField('ql-name'),
                    phone = getField('ql-phone');
                if (!name) {
                    toast('Name is required', 'error');
                    return;
                }
                const leads = LS.get('leads');
                const lead = {
                    id: genId('EG'),
                    name,
                    company: getField('ql-company'),
                    phone,
                    phone2: '',
                    whatsapp: '',
                    email: '',
                    country: getField('ql-country'),
                    city: '',
                    btype: '',
                    product: getField('ql-product'),
                    source: getField('ql-source'),
                    socialEmp: '',
                    salesEmp: getField('ql-sales'),
                    status: 'New',
                    response: 'No Response',
                    priority: getField('ql-priority'),
                    deal: 0,
                    notes: '',
                    followup: '',
                    added: new Date().toISOString()
                };
                leads.push(lead);
                LS.set('leads', leads);
                GS.pushLead(lead);
                closeModal('quick-lead-modal');
                toast('Lead saved: ' + name, 'success');
                renderLeadTable();
            }

            function clearLeadForm() {
                ['nl-name', 'nl-company', 'nl-phone', 'nl-phone2', 'nl-whatsapp', 'nl-email', 'nl-city', 'nl-deal', 'nl-notes', 'nl-followup']
                .forEach(id => {
                    const e = document.getElementById(id);
                    if (e) e.value = '';
                });
                document.getElementById('dup-alert-main').style.display = 'none';
            }

            // ═══════════════════════════════════════
            // LEAD TABLE
            // ═══════════════════════════════════════
            let leadPage = 1;
            const PER_PAGE = 15;

            function populateFilterSelects() {
                const emps = LS.get('employees').filter(e => e.role === 'sales');
                const sel = document.getElementById('f-sales');
                if (sel) {
                    sel.innerHTML = '<option value="">All Sales Reps</option>' + emps.map(e => `<option>${e.name}</option>`).join('');
                }
            }

            function getFiltered() {
                const q = (document.getElementById('lead-search') || {
                    value: ''
                }).value.toLowerCase();
                const fs = document.getElementById('f-status')?.value || '';
                const fc = document.getElementById('f-country')?.value || '';
                const fsa = document.getElementById('f-sales')?.value || '';
                const fso = document.getElementById('f-source')?.value || '';
                const fp = document.getElementById('f-priority')?.value || '';
                return getMyLeads(LS.get('leads')).filter(l => {
                    const text = (l.name + l.company + l.phone + l.email + l.id).toLowerCase();
                    const sn = empName(l.salesEmp);
                    return (!q || text.includes(q)) && (!fs || l.status === fs) && (!fc || l.country === fc) &&
                        (!fsa || sn === fsa) && (!fso || l.source === fso) && (!fp || l.priority === fp);
                });
            }

            function renderLeadTable() {
                const filtered = getFiltered();
                const total = filtered.length;
                const totalPages = Math.ceil(total / PER_PAGE);
                if (leadPage > totalPages) leadPage = 1;
                const slice = filtered.slice((leadPage - 1) * PER_PAGE, leadPage * PER_PAGE);
                const tbody = document.getElementById('leads-tbody');
                if (!tbody) return;
                document.getElementById('lead-total').textContent = getMyLeads(LS.get('leads')).length;

                if (!slice.length) {
                    tbody.innerHTML = '<tr><td colspan="13" class="table-empty">No leads found matching filters.</td></tr>';
                    return;
                }

                tbody.innerHTML = slice.map(l => `
    <tr>
      <td><input type="checkbox" class="lead-cb" data-id="${l.id}" style="cursor:pointer"></td>
      <td><span style="font-family:'DM Mono',monospace;font-size:10.5px;color:var(--text3)">${l.id}</span></td>
      <td><div style="font-weight:600;font-size:12.5px">${l.name}</div><div style="font-size:10.5px;color:var(--text3)">${l.phone}</div></td>
      <td style="color:var(--text2);font-size:12px">${l.company||'-'}</td>
      <td style="font-size:12px">${l.country||'-'}</td>
      <td style="font-size:12px">${l.product||'-'}</td>
      <td><span style="font-size:11px;color:var(--text2)">${l.source||'-'}</span></td>
      <td style="font-size:11.5px">${empName(l.salesEmp)}</td>
      <td><span class="tag ${STATUS_TAG[l.status]||'tag-new'}">${l.status}</span></td>
      <td><span class="tag ${PRI_TAG[l.priority]||'tag-medium'}">${l.priority}</span></td>
      <td>${l.samples==='yes' ? '<span style="background:#fef3c7;color:#b45309;border-radius:6px;padding:2px 8px;font-size:10.5px;font-weight:700">✅ أخذ عينات</span>' + (l.sampleResult ? '<br><span style="font-size:10px;color:var(--text3)">' + l.sampleResult + '</span>' : '') : '<span style="color:var(--text3);font-size:11px">—</span>'}</td>
      <td class="deal-cell" style="font-weight:700;color:var(--green);font-size:12px">${fmt(l.deal)}</td>
      <td>
        <div style="display:flex;gap:4px">
          <button class="btn btn-outline btn-xs" onclick="openEditLead('${l.id}')" title="Edit">✏️</button>
          <button class="btn btn-outline btn-xs" onclick="window.open('https://wa.me/'+encodeURIComponent('${l.whatsapp||l.phone}'))" title="WhatsApp">💬</button>
          <button class="btn btn-danger btn-xs" onclick="deleteLead('${l.id}')" title="Delete">🗑️</button>
        </div>
      </td>
    </tr>`).join('');

                document.getElementById('lead-count-info').textContent = `Showing ${(leadPage-1)*PER_PAGE+1}–${Math.min(leadPage*PER_PAGE,total)} of ${total}`;

                // Pagination
                const pg = document.getElementById('lead-pages');
                let html = '';
                if (leadPage > 1) html += `<button class="btn btn-outline btn-sm" onclick="goPage(${leadPage-1})">←</button>`;
                for (let i = Math.max(1, leadPage - 2); i <= Math.min(totalPages, leadPage + 2); i++) {
                    html += `<button class="btn ${i===leadPage?'btn-primary':'btn-outline'} btn-sm" onclick="goPage(${i})">${i}</button>`;
                }
                if (leadPage < totalPages) html += `<button class="btn btn-outline btn-sm" onclick="goPage(${leadPage+1})">→</button>`;
                pg.innerHTML = html;
            }

            function goPage(p) {
                leadPage = p;
                renderLeadTable();
            }

            function clearFilters() {
                ['f-status', 'f-country', 'f-sales', 'f-source', 'f-priority'].forEach(id => {
                    const e = document.getElementById(id);
                    if (e) e.value = '';
                });
                document.getElementById('lead-search').value = '';
                leadPage = 1;
                renderLeadTable();
            }

            function toggleSelectAll() {
                const all = document.getElementById('select-all').checked;
                document.querySelectorAll('.lead-cb').forEach(c => c.checked = all);
            }

            function deleteLead(id) {
                confirm('Delete Lead', 'This lead will be permanently removed.', () => {
                    const leads = LS.get('leads').filter(l => l.id !== id);
                    LS.set('leads', leads);
                    GS.deleteLead(id);
                    renderLeadTable();
                    toast('Lead deleted', 'error');
                });
            }

            function openEditLead(id) {
                const lead = LS.get('leads').find(l => l.id === id);
                if (!lead) return;
                document.getElementById('el-id').value = id;
                document.getElementById('el-status').value = lead.status;
                document.getElementById('el-priority').value = lead.priority;
                document.getElementById('el-deal').value = lead.deal || '';
                document.getElementById('el-notes').value = lead.notes || '';
                document.getElementById('el-followup').value = lead.followup || '';
                document.getElementById('el-response').value = lead.response || 'No Response';
                const salesSel = document.getElementById('el-sales');
                salesSel.innerHTML = '<option value="">Unassigned</option>' + LS.get('employees').filter(e => e.role === 'sales').map(e => `<option value="${e.id}" ${lead.salesEmp===e.id?'selected':''}>${e.name}</option>`).join('');
                document.getElementById('el-samples').value = lead.samples || 'no';
                document.getElementById('el-sample-result').value = lead.sampleResult || '';
                toggleSampleResult('el');
                openModal('edit-lead-modal');
            }

            function updateLead() {
                const id = document.getElementById('el-id').value;
                const leads = LS.get('leads');
                const i = leads.findIndex(l => l.id === id);
                if (i < 0) return;
                leads[i].status = document.getElementById('el-status').value;
                leads[i].priority = document.getElementById('el-priority').value;
                leads[i].salesEmp = document.getElementById('el-sales').value;
                leads[i].deal = parseFloat(document.getElementById('el-deal').value) || leads[i].deal;
                leads[i].notes = document.getElementById('el-notes').value;
                leads[i].samples = document.getElementById('el-samples').value;
                leads[i].sampleResult = document.getElementById('el-sample-result').value;
                leads[i].followup = document.getElementById('el-followup').value;
                leads[i].response = document.getElementById('el-response').value;
                leads[i].updated = new Date().toISOString();
                LS.set('leads', leads);
                GS.updateLead(leads[i]);
                closeModal('edit-lead-modal');
                toast('Lead updated', 'success');
                renderLeadTable();
            }

            function populateLeadFormSelects() {
                const emps = LS.get('employees');
                const sales = emps.filter(e => e.role === 'sales');
                const social = emps.filter(e => e.role === 'social');
                const sse = document.getElementById('nl-sales-emp');
                const soe = document.getElementById('nl-social-emp');
                if (sse) sse.innerHTML = '<option value="">Select</option>' + sales.map(e => `<option value="${e.id}">${e.name}</option>`).join('');
                if (soe) soe.innerHTML = '<option value="">Select</option>' + social.map(e => `<option value="${e.id}">${e.name}</option>`).join('');
                const ql = document.getElementById('ql-sales');
                if (ql) ql.innerHTML = '<option value="">Select</option>' + sales.map(e => `<option value="${e.id}">${e.name}</option>`).join('');
            }

            // ═══════════════════════════════════════
            // DASHBOARD
            // ═══════════════════════════════════════
            function renderDashboard() {
                const leads = LS.get('leads');
                const total = leads.length;
                const won = leads.filter(l => l.status === 'Closed Won').length;
                const revenue = leads.filter(l => l.status === 'Closed Won').reduce((s, l) => s + (l.deal || 0), 0);
                const conv = total ? Math.round(won / total * 100) : 0;

                document.getElementById('kpi-grid').innerHTML = `
    <div class="kpi-card"><div class="kpi-stripe" style="background:var(--navy)"></div><div class="kpi-label">Total Leads</div><div class="kpi-value">${total}</div><div class="kpi-delta up">↑ Active pipeline</div></div>
    <div class="kpi-card"><div class="kpi-stripe" style="background:var(--gold)"></div><div class="kpi-label">Deals Closed</div><div class="kpi-value">${won}</div><div class="kpi-delta up">↑ This period</div></div>
    <div class="kpi-card"><div class="kpi-stripe" style="background:var(--green)"></div><div class="kpi-label">Revenue</div><div class="kpi-value deal-kpi">${fmt(revenue)}</div><div class="kpi-delta up">↑ Growing</div></div>
    <div class="kpi-card"><div class="kpi-stripe" style="background:var(--red)"></div><div class="kpi-label">Conversion</div><div class="kpi-value">${conv}%</div><div class="kpi-delta flat">Deals / Leads</div></div>`;

                // Funnel
                const statuses = ['New', 'Contacted', 'Interested', 'Follow-up', 'Negotiation', 'Closed Won', 'Closed Lost'];
                const colors = ['#1a1f6e', '#2563eb', '#7c3aed', '#d97706', '#ea580c', '#16a34a', '#dc2626'];
                const max = total || 1;
                document.getElementById('funnel-chart').innerHTML = statuses.map((s, i) => {
                    const cnt = leads.filter(l => l.status === s).length;
                    const w = Math.max(10, Math.round(cnt / max * 100));
                    return `<div class="funnel-item"><div class="funnel-bar" style="background:${colors[i]};width:${w}%">${s} — ${cnt}</div><div class="funnel-count" style="color:${colors[i]}">${cnt}</div></div>`;
                }).join('');

                // Sources
                const srcs = ['Facebook', 'Instagram', 'LinkedIn', 'WhatsApp', 'Referral', 'Cold Call'];
                const srcColors = {
                    'Facebook': '#1877f2',
                    'Instagram': '#e1306c',
                    'LinkedIn': '#0077b5',
                    'WhatsApp': '#25d366',
                    'Referral': var_gold(),
                    'Cold Call': '#888'
                };
                const srcMax = Math.max(...srcs.map(s => leads.filter(l => l.source === s).length)) || 1;
                document.getElementById('source-chart').innerHTML = srcs.map(s => {
                    const cnt = leads.filter(l => l.source === s).length;
                    const w = Math.round(cnt / srcMax * 100);
                    return `<div class="bar-row"><div class="bar-label">${s}</div><div class="bar-track"><div class="bar-fill" style="width:${w}%;background:${srcColors[s]||'#888'}">${cnt}</div></div></div>`;
                }).join('');

                // Top sales LB
                const emps = LS.get('employees');
                const salesEmps = emps.filter(e => e.role === 'sales');
                const salesRanked = salesEmps.map(e => ({...e,
                    won: leads.filter(l => l.salesEmp === e.id && l.status === 'Closed Won').length
                })).sort((a, b) => b.won - a.won);
                document.getElementById('top-sales-lb').innerHTML = salesRanked.map((e, i) => `
    <div class="lb-item">
      <div class="rank ${['r1','r2','r3','r-n'][Math.min(i,3)]}">${i+1}</div>
      <div style="flex:1;font-size:12.5px;font-weight:500">${e.name}</div>
      <div style="font-size:12px;color:var(--text2);text-align:right"><strong style="color:var(--green)">${e.won}</strong> deals</div>
    </div>`).join('');

                // Top social LB
                const socialEmps = emps.filter(e => e.role === 'social');
                const socialRanked = socialEmps.map(e => ({...e,
                    cnt: leads.filter(l => l.socialEmp === e.id).length
                })).sort((a, b) => b.cnt - a.cnt);
                document.getElementById('top-social-lb').innerHTML = socialRanked.map((e, i) => `
    <div class="lb-item">
      <div class="rank ${['r1','r2','r3','r-n'][Math.min(i,3)]}">${i+1}</div>
      <div style="flex:1;font-size:12.5px;font-weight:500">${e.name}</div>
      <div style="font-size:12px;color:var(--text2);text-align:right"><strong style="color:var(--blue)">${e.cnt}</strong> leads</div>
    </div>`).join('');

                // Activity
                const recent = leads.slice(-4).reverse();
                document.getElementById('recent-activity').innerHTML = recent.map(l => `
    <div class="act-item">
      <div class="act-dot" style="background:${l.status==='Closed Won'?'var(--green)':l.status==='New'?'var(--amber)':'var(--blue)'}"></div>
      <div><div class="act-title">${l.status} — ${l.name}</div><div class="act-time">${ago(l.added)} · ${empName(l.salesEmp)}</div></div>
    </div>`).join('');

                // Countries
                const countries = ['Saudi Arabia', 'UAE', 'Kuwait', 'Qatar', 'Bahrain', 'Oman'];
                const cmax = Math.max(...countries.map(c => leads.filter(l => l.country === c).length)) || 1;
                document.getElementById('country-chart').innerHTML = countries.map(c => {
                    const cnt = leads.filter(l => l.country === c).length;
                    const w = Math.round(cnt / cmax * 100);
                    return `<div class="bar-row"><div class="bar-label" style="font-size:10.5px">${c}</div><div class="bar-track"><div class="bar-fill" style="width:${Math.max(5,w)}%;background:var(--navy)">${cnt}</div></div></div>`;
                }).join('');

                // Products
                const prods = ['Snacks', 'Candies', 'Gum', 'Lollipops', 'FMCG Mix', 'Custom Order'];
                const pmax = Math.max(...prods.map(p => leads.filter(l => l.product === p).length)) || 1;
                document.getElementById('product-chart').innerHTML = prods.map(p => {
