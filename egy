// ═══════════════════════════════════════
// GOOGLE SHEETS INTEGRATION
// ═══════════════════════════════════════
// Google Apps Script Web App URL - يتم إعداده من لوحة الإدارة
const GS = {
    // اللينك ده بيتحدد من Admin Panel
    get scriptUrl() { return localStorage.getItem('eg_sheets_url') || ''; },
    get sheetId() { return '1CWuACOmI4vYkuf3brZ3h1JTudQp0xrpzOH1t1km7evU'; },
    get enabled() { return !!this.scriptUrl; },
    
    headers: ['Lead ID','Full Name','Company','Phone','Alt Phone','WhatsApp','Email','Country','City','Business Type','Product Interest','Lead Source','Social Employee','Sales Employee','Status','Response','Priority','Deal Value','Notes','Follow-up Date','Date Added','Last Updated'],
    
    leadToRow(lead) {
        return [
            lead.id, lead.name, lead.company||'', lead.phone||'', lead.phone2||'',
            lead.whatsapp||'', lead.email||'', lead.country||'', lead.city||'',
            lead.btype||'', lead.product||'', lead.source||'',
            empName(lead.socialEmp), empName(lead.salesEmp),
            lead.status||'New', lead.response||'No Response', lead.priority||'Medium',
            lead.deal||0, lead.notes||'', lead.followup||'',
            lead.added||new Date().toISOString(), lead.updated||new Date().toISOString()
        ];
    },
    
    rowToLead(row) {
        if (!row || row.length < 2) return null;
        const emps = LS.get('employees');
        function findEmpByName(name) {
            if (!name) return '';
            const e = emps.find(x => x.name === name);
            return e ? e.id : '';
        }
        return {
            id: row[0] || genId('EG'),
            name: row[1] || '',
            company: row[2] || '',
            phone: row[3] || '',
            phone2: row[4] || '',
            whatsapp: row[5] || '',
            email: row[6] || '',
            country: row[7] || '',
            city: row[8] || '',
            btype: row[9] || '',
            product: row[10] || '',
            source: row[11] || '',
            socialEmp: findEmpByName(row[12]),
            salesEmp: findEmpByName(row[13]),
            status: row[14] || 'New',
            response: row[15] || 'No Response',
            priority: row[16] || 'Medium',
            deal: parseFloat(row[17]) || 0,
            notes: row[18] || '',
            followup: row[19] || '',
            added: row[20] || new Date().toISOString(),
            updated: row[21] || new Date().toISOString()
        };
    },

    async pushLead(lead) {
        if (!this.enabled) return;
        try {
            const row = this.leadToRow(lead);
            await fetch(this.scriptUrl, {
                method: 'POST',
                mode: 'no-cors',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'appendRow', sheetId: this.sheetId, row })
            });
            updateSyncStatus('↑ Lead pushed to Sheets');
        } catch(e) { console.warn('Sheets push failed:', e); }
    },

    async updateLead(lead) {
        if (!this.enabled) return;
        try {
            const row = this.leadToRow(lead);
            await fetch(this.scriptUrl, {
                method: 'POST',
                mode: 'no-cors',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'updateRow', sheetId: this.sheetId, id: lead.id, row })
            });
        } catch(e) { console.warn('Sheets update failed:', e); }
    },

    async deleteLead(leadId) {
        if (!this.enabled) return;
        try {
            await fetch(this.scriptUrl, {
                method: 'POST',
                mode: 'no-cors',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'deleteRow', sheetId: this.sheetId, id: leadId })
            });
        } catch(e) { console.warn('Sheets delete failed:', e); }
    },

    async pullAll() {
        if (!this.enabled) { toast('يجب إعداد Google Apps Script URL أولاً', 'warn'); return; }
        const btn = document.getElementById('force-sync-btn');
        if (btn) { btn.textContent = '🔄 جارٍ المزامنة...'; btn.disabled = true; }
        try {
            const resp = await fetch(this.scriptUrl + '?action=getAll&sheetId=' + this.sheetId);
            const data = await resp.json();
            if (data && data.rows && data.rows.length > 0) {
                // Skip header row
                const sheetLeads = data.rows.slice(1).map(r => this.rowToLead(r)).filter(Boolean);
                const localLeads = LS.get('leads');
                // Merge: sheet data takes precedence for existing IDs
                const localMap = {};
                localLeads.forEach(l => localMap[l.id] = l);
                sheetLeads.forEach(sl => { localMap[sl.id] = sl; });
                const merged = Object.values(localMap);
                LS.set('leads', merged);
                renderPage(currentPage || 'dashboard');
                toast(`✅ تمت المزامنة: ${sheetLeads.length} لييد من الشيت`, 'success');
                updateSyncStatus('↓ بيانات محدّثة من Sheets');
            } else {
                toast('لا توجد بيانات في الشيت أو الاتصال فشل', 'warn');
            }
        } catch(e) {
            toast('فشل الاتصال بـ Google Sheets: ' + e.message, 'error');
        } finally {
            if (btn) { btn.textContent = '🔄 مزامنة فورية'; btn.disabled = false; }
        }
    },

    async pushAll() {
        if (!this.enabled) { toast('يجب إعداد Google Apps Script URL أولاً', 'warn'); return; }
        const leads = LS.get('leads');
        try {
            const rows = [this.headers, ...leads.map(l => this.leadToRow(l))];
            await fetch(this.scriptUrl, {
                method: 'POST',
                mode: 'no-cors',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'replaceAll', sheetId: this.sheetId, rows })
            });
            toast(`✅ تم رفع ${leads.length} لييد إلى Google Sheets`, 'success');
            updateSyncStatus('↑ كل البيانات رُفعت للشيت');
        } catch(e) {
            toast('فشل رفع البيانات: ' + e.message, 'error');
        }
    }
};

var lastSyncMsg = '';
var currentPage = 'dashboard';

function updateSyncStatus(msg) {
    lastSyncMsg = msg + ' · ' + new Date().toLocaleTimeString('ar-EG');
    const el = document.getElementById('sync-status-msg');
    if (el) el.textContent = lastSyncMsg;
    const el2 = document.getElementById('sync-count');
    if (el2) el2.textContent = LS.get('leads').length;
}

// Auto sync every 5 minutes
setInterval(() => {
    if (GS.enabled) GS.pullAll();
}, 5 * 60 * 1000);

