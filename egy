function exportCSV(){
  const leads=LS.get('leads');
  const headers=['ID','Name','Company','Phone','Email','Country','City','Product','Source','Sales Rep','Status','Priority','Deal Value','Notes','Date Added'];
  const rows=leads.map(l=>[l.id,l.name,l.company,l.phone,l.email,l.country,l.city,l.product,l.source,empName(l.salesEmp),l.status,l.priority,l.deal,l.notes,l.added].map(v=>'"'+(v||'').toString().replace(/"/g,'""')+'"').join(','));
  const csv=[headers.join(','),...rows].join('\n');
  const blob=new Blob(['\ufeff'+csv],{type:'text/csv;charset=utf-8;'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='EgyGulf_Leads_'+new Date().toISOString().slice(0,10)+'.csv';a.click();
  toast('CSV exported','success');
}

